# ─────────────────────────────────────────────────────────────────────────────
# VMBS Operational Risk & Audit Register — environment configuration
# Copy to .env.local for local dev; set these in Azure App Service / Vercel for deploys.
# ─────────────────────────────────────────────────────────────────────────────

# Admin sign-in password (server-verified; gates data.xlsx upload).
# REQUIRED in production — if unset, upload is disabled.
ADMIN_PASSWORD=change-me

# Secret used to sign the admin session cookie (any long random string).
# REQUIRED in production. Generate: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string

# ── Storage driver ───────────────────────────────────────────────────────────
# The app auto-detects the driver from whichever of these is set, in this order:
#   1. AZURE_STORAGE_CONNECTION_STRING  -> azure-blob   (PRODUCTION / Microsoft)
#   2. BLOB_READ_WRITE_TOKEN            -> vercel-blob   (Vercel staging)
#   3. (none)                          -> local-fs      (writes ./.data/data.xlsx — dev only)
# You can also force it explicitly with STORAGE_DRIVER=azure-blob|vercel-blob|local-fs

# --- Azure Blob Storage (production) ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=vmbs-risk
AZURE_STORAGE_BLOB=data.xlsx

# --- Vercel Blob (staging ground) ---
# BLOB_READ_WRITE_TOKEN is injected automatically when you add Vercel Blob to the project.
BLOB_READ_WRITE_TOKEN=

# --- Explicit override (optional) ---
# STORAGE_DRIVER=local-fs
